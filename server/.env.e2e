# E2E Test Environment
# PORT is intentionally absent — Playwright sets it to a random free port via the shell.
# dotenv only overrides vars that appear in this file, so the shell PORT is preserved.

HOST=127.0.0.1
LOG_LEVEL=warn

AUTH_SECRET=e2e-test-secret-key

# No SMTP settings — ensures testToken is always returned by the magic-link endpoint
# No AI API keys — E2E tests do not make real LLM calls
